generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                     Int       @id @default(autoincrement())
  login                  String    @unique
  passwordHash           String
  salt                   String
  name                   String
  role                   Int
  banned                 Boolean   @default(false)
  refreshToken           String?
  refreshTokenExpiryTime DateTime?
  events                 Event[]

  @@map("Users")
}

model Event {
  id           Int      @id @default(autoincrement())
  userId       Int
  client       String
  reason       String
  creationTime DateTime
  status       Int
  startTime    DateTime
  endTime      DateTime
  warningsJson String
  comment      String?
  adminComment String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("Events")
}
